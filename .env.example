# New Relic Configuration
NEW_RELIC_API_KEY=your_newrelic_api_key_here
NEW_RELIC_ACCOUNT_ID=your_account_id_here
NEW_RELIC_REGION=US

# Optional: Set to EU if using New Relic EU region
# NEW_RELIC_REGION=EU

# Safety controls. Writes and destructive operations are disabled by default.
# NEW_RELIC_MCP_ENABLE_WRITES=false
# NEW_RELIC_MCP_ENABLE_DESTRUCTIVE=false
# NEW_RELIC_MCP_ALLOW_ACCOUNT_OVERRIDE=false
# NEW_RELIC_MCP_ALLOWED_TOOLS=query_nrql,list_alert_policies
# NEW_RELIC_MCP_DISABLED_TOOLS=delete_dashboard,delete_workflow
# NEW_RELIC_MCP_LOG_PAYLOADS=false
